<ContextMenu x:Class="Explorip.Explorer.Controls.PopUpExplorerContextMenuSubItems"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Explorip.Explorer.Controls"
             xmlns:constants="clr-namespace:Explorip.Constants"
             xmlns:commonConstants="clr-namespace:ExploripSharedCopy.Constants;assembly=ExploripSharedCopy"
             xmlns:config="clr-namespace:ExploripConfig.Configuration;assembly=ExploripConfig"
             xmlns:viewmodels="clr-namespace:Explorip.Explorer.ViewModels"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance Type=viewmodels:ContextMenuEntryViewModel}"
             d:DesignHeight="450" d:DesignWidth="800" StaysOpen="False" Placement="Mouse" PreviewMouseLeftButtonDown="Popup_PreviewMouseLeftButtonDown" PreviewMouseRightButtonDown="Popup_PreviewMouseRightButtonDown">

    <ContextMenu.Style>
        <Style TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="Transparent" BorderThickness="0" Padding="0">
                            <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel IsItemsHost="True" Background="Transparent" Margin="0"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ContextMenu.Style>

    <ContextMenu.Resources>
        <BooleanToVisibilityConverter x:Key="boolToVisible"/>
        <Style TargetType="Button" x:Key="BtnStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{x:Static commonConstants:Colors.SelectedBackgroundShellObject}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ContextMenu.Resources>
    
    <ContextMenu.LayoutTransform>
        <ScaleTransform ScaleX="{Binding Dpi}" ScaleY="{Binding Dpi}"/>
    </ContextMenu.LayoutTransform>
    
    <Border BorderThickness="0" CornerRadius="{x:Static config:ConfigManager.ExplorerContextMenuCornerRadius}" Background="{Binding Background}">
        <StackPanel Background="Transparent" Margin="{x:Static config:ConfigManager.ExplorerContextMenuMargin}" Orientation="Vertical" HorizontalAlignment="Left">

            <ItemsControl ItemsSource="{Binding SubItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Button Foreground="{Binding DataContext.Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:PopUpExplorerContextMenuSubItems}}" BorderThickness="0" Margin="5 0 0 0" Visibility="{Binding IsVisible, Converter={StaticResource boolToVisible}}" IsEnabled="{Binding IsEnabled}" Command="{Binding ExecuteCommand}" Style="{StaticResource BtnStyle}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseEnter">
                                        <i:InvokeCommandAction Command="{Binding MouseEnterCommand}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="MouseLeave">
                                        <i:InvokeCommandAction Command="{Binding MouseLeaveCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Source="{Binding Entry.Icon}" Margin="0 0 5 0" VerticalAlignment="Center" Visibility="{Binding IconVisible, Converter={StaticResource boolToVisible}}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Label}" Margin="4 4 0 4"/>
                                    <TextBlock Grid.Column="2" Text=">" FontWeight="Bold" VerticalAlignment="Center" Margin="0 0 4 0" Visibility="{Binding HasSubItems, Converter={StaticResource boolToVisible}}"/>
                                </Grid>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
    
</ContextMenu>
