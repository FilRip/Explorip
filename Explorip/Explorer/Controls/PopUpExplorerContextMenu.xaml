<ContextMenu x:Class="Explorip.Explorer.Controls.PopUpExplorerContextMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Explorip.Explorer.Controls"
             xmlns:constants="clr-namespace:Explorip.Constants"
             xmlns:commonConstants="clr-namespace:ExploripSharedCopy.Constants;assembly=ExploripSharedCopy"
             xmlns:config="clr-namespace:ExploripConfig.Configuration;assembly=ExploripConfig"
             xmlns:viewmodels="clr-namespace:Explorip.Explorer.ViewModels"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800" Placement="Mouse" IsOpen="{Binding IsOpen}" PreviewMouseLeftButtonDown="Popup_PreviewMouseLeftButtonDown" PreviewMouseRightButtonDown="Popup_PreviewMouseRightButtonDown">

    <ContextMenu.Style>
        <Style TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="Transparent" BorderThickness="0" Padding="0">
                            <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel IsItemsHost="True" Background="Transparent" Margin="0"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ContextMenu.Style>
    
    <ContextMenu.Resources>
        <BooleanToVisibilityConverter x:Key="boolToVisible"/>
        <Style TargetType="Button" x:Key="BtnStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{x:Static commonConstants:Colors.SelectedBackgroundShellObject}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </ContextMenu.Resources>
    
    <ContextMenu.DataContext>
        <viewmodels:PopUpExplorerContextMenuViewModel/>
    </ContextMenu.DataContext>

    <ContextMenu.LayoutTransform>
        <ScaleTransform ScaleX="{Binding Dpi}" ScaleY="{Binding Dpi}"/>
    </ContextMenu.LayoutTransform>
    
    <Border BorderThickness="0" CornerRadius="{x:Static config:ConfigManager.ExplorerContextMenuCornerRadius}" Background="{Binding Background}">
        <StackPanel Background="Transparent" Margin="{x:Static config:ConfigManager.ExplorerContextMenuMargin}" Orientation="Vertical" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal">
                
                <Button Foreground="{Binding Foreground}" BorderThickness="0" Visibility="{Binding VisibleCut, Converter={StaticResource boolToVisible}}" Command="{Binding CutCommand}" Style="{StaticResource BtnStyle}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" Margin="0 4 0 2"/>
                        <TextBlock Text="{x:Static constants:Localization.CUT}" Margin="4 2 4 4"/>
                    </StackPanel>
                </Button>

                <Button Foreground="{Binding Foreground}" BorderThickness="0" Margin="5 0 0 0" Visibility="{Binding VisibleCopy, Converter={StaticResource boolToVisible}}" Command="{Binding CopyCommand}" Style="{StaticResource BtnStyle}">
                    <StackPanel>
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" Margin="0 4 0 2"/>
                        <TextBlock Text="{x:Static constants:Localization.COPY}" Margin="4 2 4 4"/>
                    </StackPanel>
                </Button>

                <Button Foreground="{Binding Foreground}" BorderThickness="0" Margin="5 0 0 0" Visibility="{Binding VisiblePaste, Converter={StaticResource boolToVisible}}" Command="{Binding PasteCommand}" Style="{StaticResource BtnStyle}">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" Margin="0 4 0 2"/>
                        <TextBlock Text="{x:Static constants:Localization.PASTE}" Margin="4 2 4 4"/>
                    </StackPanel>
                </Button>

                <Button Foreground="{Binding Foreground}" BorderThickness="0" Margin="5 0 0 0" Visibility="{Binding VisibleDelete, Converter={StaticResource boolToVisible}}" Command="{Binding DeleteCommand}" Style="{StaticResource BtnStyle}">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" Margin="0 4 0 2"/>
                        <TextBlock Text="{x:Static constants:Localization.DELETE}" Margin="4 2 4 4"/>
                    </StackPanel>
                </Button>
                
            </StackPanel>

            <Line X1="1" Y1="1" Stretch="Fill" Stroke="{x:Static commonConstants:Colors.ForegroundColorBrush}" Margin="0 5 0 0"/>

            <ItemsControl ItemsSource="{Binding ListContextMenuEntry}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Button Foreground="{Binding DataContext.Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:PopUpExplorerContextMenu}}" BorderThickness="0" Margin="5 0 0 0" Visibility="{Binding IsVisible, Converter={StaticResource boolToVisible}}" IsEnabled="{Binding IsEnabled}" Command="{Binding ExecuteCommand}" Style="{StaticResource BtnStyle}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseEnter">
                                        <i:InvokeCommandAction Command="{Binding MouseEnterCommand}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="MouseLeave">
                                        <i:InvokeCommandAction Command="{Binding MouseLeaveCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Grid.Column="0" Source="{Binding Entry.Icon}" Margin="0 0 5 0" VerticalAlignment="Center" Visibility="{Binding IconVisible, Converter={StaticResource boolToVisible}}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Label}" Margin="4 4 0 4"/>
                                    <TextBlock Grid.Column="2" Text=">" FontWeight="Bold" VerticalAlignment="Center" Margin="0 0 4 0" Visibility="{Binding HasSubItems, Converter={StaticResource boolToVisible}}"/>
                                </Grid>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Line X1="1" Y1="1" Stretch="Fill" Stroke="{x:Static commonConstants:Colors.ForegroundColorBrush}" Margin="0 5 0 0"/>

            <Button Foreground="{Binding Foreground}" BorderThickness="0" Margin="0 5 0 0" Command="{Binding GetPropertiesCommand}" Style="{StaticResource BtnStyle}" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static constants:Localization.PROPERTIES}" Margin="4 4 0 4"/>
                </StackPanel>
            </Button>

            <Line X1="1" Y1="1" Stretch="Fill" Stroke="{x:Static commonConstants:Colors.ForegroundColorBrush}" Margin="0 5 0 0"/>

            <Button Foreground="{Binding Foreground}" BorderThickness="0" Margin="0 5 0 0" Command="{Binding ShowOlderContextMenuCommand}" Style="{StaticResource BtnStyle}" HorizontalAlignment="Stretch" Name="BtnOlderCM" Focusable="True" IsTabStop="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xEE47;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="4 0 0 0"/>
                    <TextBlock Text="{x:Static constants:Localization.SHOW_PREVIOUS_CONTEXTMENU}" Margin="4 4 0 4"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
    
</ContextMenu>
