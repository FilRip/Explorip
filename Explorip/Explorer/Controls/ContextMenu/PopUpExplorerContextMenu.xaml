<Window x:Class="Explorip.Explorer.Controls.ContextMenu.PopUpExplorerContextMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:Explorip.Explorer.Controls.ContextMenu"
        xmlns:constants="clr-namespace:Explorip.Constants"
        xmlns:commonConstants="clr-namespace:ExploripSharedCopy.Constants;assembly=ExploripSharedCopy"
        xmlns:config="clr-namespace:ExploripConfig.Configuration;assembly=ExploripConfig"
        xmlns:viewmodels="clr-namespace:Explorip.Explorer.ViewModels"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        ShowInTaskbar="False" WindowStyle="None" Loaded="Window_Loaded" SizeToContent="WidthAndHeight" AllowsTransparency="True" Background="Transparent" ResizeMode="NoResize" Margin="0"
        d:DesignHeight="450" d:DesignWidth="800" SizeChanged="Window_SizeChanged" PreviewKeyUp="Window_PreviewKeyUp">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="boolToVisible"/>
        <Style TargetType="Button" x:Key="BtnStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{x:Static commonConstants:Colors.SelectedBackgroundShellObject}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Window.DataContext>
        <viewmodels:PopUpExplorerContextMenuViewModel/>
    </Window.DataContext>

    <Window.LayoutTransform>
        <ScaleTransform ScaleX="{Binding Dpi}" ScaleY="{Binding Dpi}"/>
    </Window.LayoutTransform>
    
    <Border BorderThickness="0" CornerRadius="{x:Static config:ConfigManager.ExplorerContextMenuCornerRadius}" Background="{Binding Background}" Margin="0">
        <StackPanel Background="Transparent" Margin="{x:Static config:ConfigManager.ExplorerContextMenuMargin}" Orientation="Vertical" HorizontalAlignment="Left">
            
            <StackPanel Orientation="Horizontal">
                <Button Foreground="{Binding ForegroundCut}" BorderThickness="0" Visibility="{Binding VisibleCut, Converter={StaticResource boolToVisible}}" Command="{Binding CutCommand}" Style="{StaticResource BtnStyle}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseEnter">
                            <i:InvokeCommandAction Command="{Binding MouseEnterCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8C6;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" Margin="0 4 0 2"/>
                        <AccessText Text="{x:Static constants:Localization.CUT}" Margin="4 2 4 4"/>
                    </StackPanel>
                </Button>
                <Button Foreground="{Binding ForegroundCopy}" BorderThickness="0" Margin="5 0 0 0" Visibility="{Binding VisibleCopy, Converter={StaticResource boolToVisible}}" Command="{Binding CopyCommand}" Style="{StaticResource BtnStyle}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseEnter">
                            <i:InvokeCommandAction Command="{Binding MouseEnterCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <StackPanel>
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" Margin="0 4 0 2"/>
                        <AccessText Text="{x:Static constants:Localization.COPY}" Margin="4 2 4 4"/>
                    </StackPanel>
                </Button>
                <Button Foreground="{Binding ForegroundPaste}" BorderThickness="0" Margin="5 0 0 0" Visibility="{Binding VisiblePaste, Converter={StaticResource boolToVisible}}" Command="{Binding PasteCommand}" Style="{StaticResource BtnStyle}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseEnter">
                            <i:InvokeCommandAction Command="{Binding MouseEnterCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" Margin="0 4 0 2"/>
                        <AccessText Text="{x:Static constants:Localization.PASTE}" Margin="4 2 4 4"/>
                    </StackPanel>
                </Button>
                <Button Foreground="{Binding ForegroundDelete}" BorderThickness="0" Margin="5 0 0 0" Visibility="{Binding VisibleDelete, Converter={StaticResource boolToVisible}}" Command="{Binding DeleteCommand}" Style="{StaticResource BtnStyle}">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseEnter">
                            <i:InvokeCommandAction Command="{Binding MouseEnterCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" Margin="0 4 0 2"/>
                        <AccessText Text="{x:Static constants:Localization.DELETE}" Margin="4 2 4 4"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Rectangle Stroke="{x:Static commonConstants:Colors.ForegroundColorBrush}" Height="1" Stretch="Fill"/>

            <ItemsControl ItemsSource="{Binding ListContextMenuEntry}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Foreground="{Binding DataContext.Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:PopUpExplorerContextMenu}}" BorderThickness="0" Margin="5 0 0 0" Visibility="{Binding IsVisible, Converter={StaticResource boolToVisible}}" IsEnabled="{Binding IsEnabled}" Command="{Binding ExecuteCommand}" Style="{StaticResource BtnStyle}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseEnter">
                                    <i:InvokeCommandAction Command="{Binding MouseEnterCommand}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="MouseLeave">
                                    <i:InvokeCommandAction Command="{Binding MouseLeaveCommand}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="{Binding Entry.Icon}" Margin="0 0 5 0" VerticalAlignment="Center" Visibility="{Binding IconVisible, Converter={StaticResource boolToVisible}}"/>
                                <AccessText Grid.Column="1" Text="{Binding Label}" Margin="4 4 0 4"/>
                                <TextBlock Grid.Column="2" Text=">" FontWeight="Bold" VerticalAlignment="Center" Margin="0 0 4 0" Visibility="{Binding HasSubItems, Converter={StaticResource boolToVisible}}"/>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Rectangle Stroke="{x:Static commonConstants:Colors.ForegroundColorBrush}" Height="1" Stretch="Fill"/>

            <Button Foreground="{Binding Foreground}" BorderThickness="0" Margin="0 5 0 0" Command="{Binding GetPropertiesCommand}" Style="{StaticResource BtnStyle}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseEnter">
                        <i:InvokeCommandAction Command="{Binding MouseEnterCommand}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <StackPanel Orientation="Horizontal">
                    <AccessText Text="{x:Static constants:Localization.PROPERTIES}" Margin="4 4 0 4"/>
                </StackPanel>
            </Button>

            <Rectangle Stroke="{x:Static commonConstants:Colors.ForegroundColorBrush}" Height="1" Stretch="Fill"/>

            <Button Foreground="{Binding Foreground}" BorderThickness="0" Margin="0 5 0 0" Command="{Binding ShowOlderContextMenuCommand}" Style="{StaticResource BtnStyle}" Name="BtnOlderCM" Focusable="True" IsTabStop="True">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseEnter">
                        <i:InvokeCommandAction Command="{Binding MouseEnterCommand}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xEE47;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="4 0 0 0"/>
                    <AccessText Text="{x:Static constants:Localization.SHOW_PREVIOUS_CONTEXTMENU}" Margin="4 4 0 4"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
    
</Window>
